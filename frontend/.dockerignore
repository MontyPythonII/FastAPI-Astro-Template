# Without this, `COPY . .` in the build stage overwrites the node_modules that
# `npm ci` just installed with the host's copy — which may hold binaries built
# for a different platform, and busts the dependency layer cache on every edit.
node_modules/

# Build artifacts: regenerated inside the image by `npm run build`.
dist/
.astro/

.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Never bake secrets into an image layer.
.env
.env.*
!.env.example

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

Dockerfile
.dockerignore
README.md
CLAUDE.md
AGENTS.md
