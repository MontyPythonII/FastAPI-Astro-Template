---
import Layout from '../layouts/Layout.astro';

// Middleware already guarantees a signed-in user on this route; the guard here
// is for the type checker and defence in depth.
const user = Astro.locals.user;
if (!user)
{
    return Astro.redirect('/login');
}
---

<Layout title="Dashboard">
	<section class="card">
		<h1>Welcome</h1>
		<p class="muted">Signed in as <strong>{user.email}</strong>.</p>

		<dl class="details">
			<div><dt>User ID</dt><dd><code>{user.id}</code></dd></div>
			<div><dt>Email</dt><dd>{user.email}</dd></div>
			<div><dt>Active</dt><dd>{user.isActive ? 'Yes' : 'No'}</dd></div>
			<div><dt>Verified</dt><dd>{user.isVerified ? 'Yes' : 'No'}</dd></div>
			<div><dt>Superuser</dt><dd>{user.isSuperuser ? 'Yes' : 'No'}</dd></div>
		</dl>

		<div class="actions">
			<a class="button" href="/profile">Edit profile</a>
			{user.isSuperuser && <a class="button secondary" href="/admin">Admin</a>}
		</div>
	</section>
</Layout>
