# ─────────────────────────────────────────────────────────────
#  FastAPI-Astro-Template — environment template
#
#  Copy this to .env and fill in real values:
#      cp .env.example .env
#
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────
# Signs every JWT login, password-reset, and verification token.
# Anyone who knows this value can forge a login as any user.
# Generate a fresh one with:   openssl rand -hex 32
AUTH_SECRET=SECRET

# ── OPTIONAL ────────────────────────────────────────────────
# Host port the site is published on — the one you type in the browser.
WEB_PORT=7071

# Port the FastAPI backend binds. Compose feeds it to the container, the
# healthcheck, and the frontend's BACKEND_BASE_URL, so this one value moves
# the whole API. Note that `python main.py` reads it from the shell
# environment, not from this file — see the README for local dev.
SERVER_PORT=7070

# Compose project name — prefixes container and volume names, e.g.
# fastapi-astro-template-backend-1 and fastapi-astro-template_db-data.
COMPOSE_PROJECT_NAME=fastapi-astro-template

# local | staging | production
ENVIRONMENT=local

# Compose merges these files left to right. Left unset, only the base file
# runs and the backend stays unpublished — reachable from the frontend
# container but not from the host, which is what production wants.
#
# Set ENVIRONMENT=local above, then uncomment the line below, to also merge
# docker-compose.local.yml, which publishes the API on 127.0.0.1:$SERVER_PORT
# so you can open http://localhost:7070/docs. Compose cannot read ENVIRONMENT
# to decide this for itself, so the two lines are changed together.
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# Admin account, ensured at every startup: created if missing, and promoted to superuser if it already exists. Leave both blank to skip entirely

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

